{
  "core": {
    "workingDir": ".reg",
    "actualDir": "__screenshots__",
    "thresholdRate": 0.03,
    "thresholdPixel": 50,
    "addIgnore": true,
    "ximgdiff": {
      "invocationType": "client"
    }
  },
  "plugins": {
    "reg-keygen-git-hash-plugin": true,
    "reg-notify-github-plugin": {
      "clientId": "${REG_NOTIFY_CLIENT_ID}",
      "prComment": true,
      "prCommentBehavior": "new"
    }
  }
}
